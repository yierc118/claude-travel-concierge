# AirLabs API — flight departure monitoring (day-of tracking for booked flights)
# Get key at: https://airlabs.co
AIRLABS_API_KEY=your_key_here

# SerpAPI — optional, for hotelclaw Google Hotels scraping
# Get key at: https://serpapi.com (free tier: 100 searches/month)
# Leave blank to skip Google Hotels source in hotelclaw
SERPAPI_KEY=

# Dashboard server port (default: 8000)
DASHBOARD_PORT=8000

# Gmail — send emails via Gmail API (budget reports, booking confirmations)
# Credentials JSON downloaded from Google Cloud Console (OAuth 2.0 Desktop app)
# Run once to authenticate: python3 tools/gmail_send.py --auth
GMAIL_SENDER=clawdia.12.ai@gmail.com
GMAIL_CREDENTIALS_PATH=~/.config/travel-concierge/gmail-credentials.json
GMAIL_TOKEN_PATH=~/.config/travel-concierge/gmail-token.json

# Vapi — outbound phone calls for phone-only venue bookings
# Get API key at: https://dashboard.vapi.ai
# VAPI_PHONE_NUMBER_ID: find in Vapi dashboard > Phone Numbers > click your number > copy the ID from the URL
VAPI_API_KEY=
VAPI_PHONE_NUMBER_ID=

# Yier's loyalty & frequent flyer account numbers
KRISFLYER_ID=
ASIAMILES_ID=
MARRIOTT_ID=
HYATT_ID=
TRIPCOM_ID=
BOOKINGCOM_ID=
